TYLERRAW_EMAIL=your-email@example.com
TYLERRAW_PASSWORD=your-password

# Persistent browser profile directory.
# Use an existing Chrome profile if you want to reuse a logged-in session,
# or leave the default to create a local automation profile.
#
# Windows example:
# TYLERRAW_CHROME_PROFILE=C:\Users\YourName\AppData\Local\Google\Chrome\User Data\Profile 1
TYLERRAW_CHROME_PROFILE=.browser-data

# Output directory for downloaded videos
OUTPUT_DIR=./downloads

# Parallel fragment downloads for yt-dlp
YTDLP_CONCURRENT_FRAGMENTS=16

# Run browser without a visible window
HEADLESS=false
